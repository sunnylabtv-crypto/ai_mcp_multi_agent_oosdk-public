# Enterprise AI Multi-Agent Server - 환경변수 예시
# 이 파일을 복사하여 .env로 만들고, 실제 값을 입력하세요

# ============================================================
# 서버 설정
# ============================================================
MCP_MODE=sse          # sse (원격) 또는 stdio (로컬)
MCP_PORT=9100         # MCP 서버 포트 (OOSDK 실험 버전)
LOG_API_PORT=9101     # 로그 API 포트 (OOSDK 실험 버전)
DASHBOARD_PORT=9601   # Streamlit 대시보드 포트 (OOSDK 실험 버전)

# ============================================================
# Agent LLM 설정
# ============================================================
AGENT_LLM_PROVIDER=openai
AGENT_LLM_MODEL=gpt-4o-mini
AGENT_TEMPERATURE=0.3
AGENT_MAX_TOKENS=2000

# ============================================================
# OpenAI API
# ============================================================
OPENAI_API_KEY=sk-proj-your-api-key-here

# ============================================================
# Gmail 설정
# ============================================================
GMAIL_CREDENTIALS_PATH=credentials/credentials_new.json
GMAIL_TOKEN=          # Base64 encoded token (Cloud 환경용)
GMAIL_TOKEN_FINANCE=  # Finance 사용자용 토큰

# ============================================================
# Salesforce JWT Bearer Flow
# ============================================================
SF_CLIENT_ID=your-consumer-key
SF_USERNAME=your-username@salesforce.com
SF_LOGIN_URL=https://your-instance.salesforce.com
SF_PRIVATE_KEY=       # JWT private key content

# ============================================================
# VectorDB (ChromaDB)
# ============================================================
CHROMA_PERSIST_DIR=/app/data/multi/chromadb
COLLECTION_NAME=it_helpdesk_docs

# ============================================================
# Odoo ERP (BC2+)
# ============================================================
# 4개 모두 필수 — refactor (2026-05-18) 이후 코드 내 default 제거됨.
# 미설정 시 erp_agent 는 plan-only 모드로 동작 (실제 Odoo 호출 skip).
ODOO_URL=https://your-tenant.odoo.com
ODOO_DB=your_db_name
ODOO_USERNAME=your.user@example.com
ODOO_API_KEY=your-odoo-api-key
